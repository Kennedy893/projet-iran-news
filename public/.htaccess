<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /S6/projet-iran-news/public/

    # Laisser passer les fichiers et dossiers existants
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Exemple SEO-friendly : /article/12-tensions-en-iran-nouvelles-sanctions
    RewriteRule ^article/([0-9]+)-([a-zA-Z0-9-]+)$ index.php?article_id=$1&slug=$2 [L,QSA]

    # Toutes les autres requêtes vers index.php
    RewriteRule ^ index.php [L,QSA]
</IfModule>
